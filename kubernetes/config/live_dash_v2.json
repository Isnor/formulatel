              "maxDataPoints": 2500,
              "timeFrom": "600s",
              "timeShift": "600s"
            },
            "transformations": [
              {
                "group": "extractFields",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "delimiter": ",",
                    "format": "json",
                    "jsonPaths": [
                      {
                        "path": "positionX"
                      },
                      {
                        "path": "positionY"
                      },
                      {
                        "path": "velocityX"
                      },
                      {
                        "path": "velocityY"
                      },
                      {
                        "path": "velocityZ"
                      }
                    ],
                    "keepTime": true,
                    "replace": true,
                    "source": "motionData"
                  }
                }
              },
              {
                "group": "calculateField",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "alias": "velocity_sum",
                    "cumulative": {
                      "field": "positionX",
                      "reducer": "sum"
                    },
                    "mode": "reduceRow",
                    "reduce": {
                      "include": [
                        "velocityY",
                        "velocityZ",
                        "velocityX"
                      ],
                      "reducer": "sum"
                    },
                    "replaceFields": false,
                    "unary": {
                      "fieldName": "velocityX",
                      "operator": "exp"
                    }
                  }
                }
              }
            ]
          }
        },
